# Application
APP_ENV=production
PROJECT_NAME=Crop Disease Detection API
PROJECT_VERSION=0.1.0
API_PREFIX=/api/v1

# Security
# Set a long random value here in your real `.env`.
API_KEY=replace-with-a-long-random-secret
# If omitted, API key protection is enabled automatically whenever API_KEY is set.
REQUIRE_API_KEY=true
# Keep docs off in production so OpenAPI/Swagger are not exposed publicly.
ENABLE_API_DOCS=false

# Upload limits
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp

# Confidence thresholds
MIN_CROP_CONFIDENCE=0.80
CAUTION_CROP_CONFIDENCE=0.60
MIN_DISEASE_CONFIDENCE=0.75
CAUTION_DISEASE_CONFIDENCE=0.55
